{
  "name": "agentic-rewind-mcp",
  "version": "0.1.0",
  "description": "Agentic code-change safety layer with MCP tools, observe-only hooks, checkpointing, risk assessment, recommendations, and decision memory.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agentic-rewind": "./dist/cli.js",
    "agentic-rewind-mcp": "./dist/mcp-server.js"
  },
  "files": [
    "dist",
    ".github/hooks/agentic-rewind.json",
    ".vscode/mcp.json",
